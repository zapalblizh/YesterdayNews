<!DOCTYPE html>
<html class="dark" lang="en" x-data="xDOM">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        {# Metadata #}
        <title>{{ title }}</title>
        <meta name="author" content="Aleksandr Zapparov">
        <meta name="description" content="Temporary description">
        <meta name="generator" content="{{ eleventy.generator }}">

        {# Styles #}
        <link rel="preload" href="/css/main.css" as="style">
        <link rel="stylesheet" href="/css/main.css">

        {# Config Theme #}
        <script>
            const isDark = localStorage.theme === "dark" || (!("theme" in localStorage) && window.matchMedia("(prefers-color-scheme: dark)").matches);
            document.documentElement.classList.toggle("dark", isDark);
        </script>
    </head>
    <body class="max-w-7xl mx-auto bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100">
        <a href="#skip" class="sr-only">Skip to main content</a>

        {% include "../partials/header.njk" %}

        <main id="#skip" class="max-w-6xl mx-auto p-6">
            {{ content | safe }}
        </main>

        <script src="/js/main.js"></script>
    </body>
</html>