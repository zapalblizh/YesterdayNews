<!DOCTYPE html>
<html class="dark" lang="en" x-data="xDOM">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        {# Metadata #}
        <title>{{ title or metadata.title }}</title>
        <meta name="author" content="{{ metadata.author.name }}">
        <meta name="description" content="{{ description or metadata.description }}">
        <meta name="generator" content="{{ eleventy.generator }}">
        <link rel="canonical" href="{{ metadata.url }}{{ page.url }}">

        {# Styles #}
        <link rel="preload" href="/css/main.css" as="style">
        <link rel="stylesheet" href="/css/main.css">

        {# Config Theme #}
        <script>
            const isDark = localStorage.theme === "dark" || (!("theme" in localStorage) && window.matchMedia("(prefers-color-scheme: dark)").matches);
            document.documentElement.classList.toggle("dark", isDark);
        </script>
    </head>
    <body class="max-w-7xl mx-auto bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100">
        <a href="#skip" class="focus:top-0 sr-only">Skip to main content</a>

        {% include "../partials/header.njk" %}

        <main id="skip" class="max-w-6xl mx-auto p-6">
            {{ content | safe }}
        </main>

        <footer class="border-t-4 border-dashed border-gray-200 dark:border-gray-800 p-4 mt-8 text-center text-sm text-gray-500 dark:text-gray-400">
            <span>&copy; {{ build.timestamp.year }} YesterdayNews</span>
        </footer>

        <script src="/js/main.js"></script>
    </body>
</html>